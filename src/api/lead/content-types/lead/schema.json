{
  "kind": "collectionType",
  "collectionName": "leads",
  "info": {
    "singularName": "lead",
    "pluralName": "leads",
    "displayName": "Lead",
    "description": "Contact-us inquiries"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "subject": {
      "type": "string"
    },
    "message": {
      "type": "richtext"
    },
    "phone": {
      "type": "string"
    },
    "consent": {
      "type": "boolean",
      "default": false
    },
    "notificationSent": {
      "type": "boolean",
      "default": false
    },
    "notificationChannel": {
      "type": "enumeration",
      "enum": [
        "none",
        "rcs",
        "sms"
      ],
      "default": "none"
    },
    "notificationStatus": {
      "type": "string"
    },
    "notificationMessageId": {
      "type": "string"
    },
    "notificationResponse": {
      "type": "json"
    }
  }
}
