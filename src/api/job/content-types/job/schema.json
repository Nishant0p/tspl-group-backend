{
  "kind": "collectionType",
  "collectionName": "jobs",
  "info": {
    "singularName": "job",
    "pluralName": "jobs",
    "displayName": "Job",
    "description": "Published and draft job postings"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "draft",
        "published"
      ],
      "default": "draft",
      "required": true
    },
    "rcsTemplateCode": {
      "type": "string"
    },
    "description": {
      "type": "richtext"
    },
    "applicants": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::applicant.applicant",
      "mappedBy": "job"
    }
  }
}
